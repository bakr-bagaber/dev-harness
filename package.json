{
  "name": "dev-harness-cli",
  "version": "3.0.1",
  "description": "Agent-agnostic software development harness CLI — scaffold, phase orchestration, gate validation for any coding agent",
  "type": "module",
  "bin": {
    "dev-harness": "cli/dev-harness.mjs"
  },
  "files": [
    "cli/",
    "templates/",
    "schema/",
    "adapters/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Bakr Bagaber",
  "repository": {
    "type": "git",
    "url": "https://github.com/bakr-bagaber/dev-harness"
  },
  "homepage": "https://github.com/bakr-bagaber/dev-harness#readme",
  "bugs": {
    "url": "https://github.com/bakr-bagaber/dev-harness/issues"
  },
  "keywords": [
    "harness",
    "developer-tools",
    "ai-agents",
    "phase-pipeline",
    "gate-validation",
    "scaffold",
    "cli"
  ],
  "scripts": {
    "lint": "eslint cli/",
    "lint:fix": "eslint cli/ --fix",
    "check": "node --check cli/dev-harness.mjs && echo 'Syntax OK'",
    "test": "node test/run-all.mjs",
    "test:verbose": "node test/run-all.mjs --verbose",
    "postinstall": "node -e \"try{process.stdout.write('dev-harness installed. Run: npx dev-harness --help\\n')}catch(e){}\""
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ink": "^5.1.0",
    "p-retry": "^6.2.1",
    "picocolors": "^1.1.1",
    "react": "^18.3.1",
    "simple-git": "^3.27.0",
    "string-width": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
