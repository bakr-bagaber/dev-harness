    "detectFiles": [
      "CMakeLists.txt",
      "Makefile"
    ],
    "pairExts": [
      ".cpp",
      ".hpp",
      ".cc"
    ],
    "coverageCmd": "mkdir -p build && cd build && cmake .. -DCMAKE_BUILD_TYPE=Debug && make && ctest -T coverage 2>/dev/null || ctest"
  },
