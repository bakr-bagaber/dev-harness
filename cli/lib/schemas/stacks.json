{
  "python": {
    "label": "Python",
    "testCmd": "python3 -m pytest",
    "lintCmd": "python3 -m ruff check",
    "typeCheckCmd": "python3 -m mypy",
    "buildCmd": "python3 -m build",
    "installCmd": "python3 -m pip install -e .",
    "versionFile": ".python-version",
    "configFile": "pyproject.toml",
    "extensions": [
      ".py"
    ],
    "detectFiles": [
      "pyproject.toml",
      "setup.py",
      "requirements.txt",
      "Pipfile"
    ],
    "coverageCmd": "python3 -m pytest --cov --cov-report=term-missing --cov-fail-under=80"
  },
  "node": {
    "label": "Node.js",
    "testCmd": "npm test",
    "lintCmd": "npx eslint .",
    "typeCheckCmd": "npx tsc --noEmit",
    "buildCmd": "npm run build",
    "installCmd": "npm install",
    "versionFile": ".nvmrc",
    "configFile": "package.json",
    "extensions": [
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".mjs"
    ],
    "detectFiles": [
      "package.json",
      "tsconfig.json",
      "yarn.lock",
      "pnpm-lock.yaml"
    ],
    "coverageCmd": "npx c8 --reporter=text --reporter=lcov npm test"
  },
  "go": {
    "label": "Go",
    "testCmd": "go test ./...",
    "lintCmd": "go vet ./...",
    "typeCheckCmd": "go build ./...",
    "buildCmd": "go build ./...",
    "installCmd": "go mod download",
    "versionFile": "go.ver",
    "configFile": "go.mod",
    "extensions": [
      ".go"
    ],
    "detectFiles": [
      "go.mod"
    ],
    "coverageCmd": "go test -coverprofile=cover.out ./... && go tool cover -func=cover.out"
  },
  "rust": {
    "label": "Rust",
    "testCmd": "cargo test",
    "lintCmd": "cargo clippy -- -D warnings",
    "typeCheckCmd": "cargo check",
    "buildCmd": "cargo build",
    "installCmd": "cargo build",
    "versionFile": "rust-toolchain.toml",
    "configFile": "Cargo.toml",
    "extensions": [
      ".rs"
    ],
    "detectFiles": [
      "Cargo.toml"
    ],
    "coverageCmd": "cargo tarpaulin --out xml --target-dir target/tarpaulin 2>/dev/null || cargo test"
  },
  "c": {
    "label": "C",
    "testCmd": "ctest --output-on-failure",
    "lintCmd": "gcc -Wall -Wextra -pedantic -std=c17 -fsyntax-only $(find . -name '*.c')",
    "typeCheckCmd": "",
    "buildCmd": "mkdir -p build && cd build && cmake .. && make",
    "installCmd": "apt-get install -y build-essential cmake 2>/dev/null || brew install cmake 2>/dev/null",
    "versionFile": "",
    "configFile": "CMakeLists.txt",
    "extensions": [
      ".c"
    ],
    "detectFiles": [
      "CMakeLists.txt",
      "Makefile"
    ],
    "pairExts": [
      ".c"
    ],
    "coverageCmd": "mkdir -p build && cd build && cmake .. -DCMAKE_BUILD_TYPE=Debug && make && ctest -T coverage 2>/dev/null || ctest"
  },
  "cpp": {
    "label": "C++",
    "testCmd": "ctest --output-on-failure",
    "lintCmd": "clang++ -Wall -Wextra -std=c++20 -fsyntax-only $(find . -name '*.cpp' -o -name '*.hpp')",
